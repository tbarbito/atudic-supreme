[flake8]
max-line-length = 120
exclude =
    venv,
    __pycache__,
    .git,
    build,
    dist,
    aturpo_win,
    htmlcov,
    planos
ignore =
    # whitespace before ':' (conflita com black)
    E203,
    # line too long (gerenciado pelo black)
    E501,
    # line break before binary operator (conflita com black)
    W503
per-file-ignores =
    # imports no __init__ podem ser unused
    __init__.py:F401
