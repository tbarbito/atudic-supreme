# === AtuDIC Supreme — Configuracao ===

# Flask
SECRET_KEY=change-me-in-production
FLASK_DEBUG=0
HOST=0.0.0.0
PORT=5000

# PostgreSQL (plataforma)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=atudic_supreme
DB_USER=postgres
DB_PASSWORD=
DB_POOL_MIN=2
DB_POOL_MAX=30

# LLM Provider (ollama, openai, anthropic, google, xai, deepseek, openrouter, groq, mistral, together)
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1
LLM_API_KEY=

# Embedding Provider (mesmo provider ou independente)
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=mxbai-embed-large

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5000

# Logging
LOG_LEVEL=INFO
