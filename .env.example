# =====================================================================
# AtuDIC Supreme — Configuracao de Ambiente
# =====================================================================
# Copie este arquivo para .env e ajuste os valores para seu ambiente.
#   cp .env.example .env
#
# IMPORTANTE: nunca commite o arquivo .env (ja esta no .gitignore)
# =====================================================================

# --- Banco de Dados PostgreSQL ---
DB_TYPE=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=atudic_supreme
DB_USER=atudic_supreme
DB_PASSWORD=atudic_supreme_2026

# Pool de conexoes (ajustar conforme carga)
# DB_POOL_MIN=2
# DB_POOL_MAX=30

# SSL para banco remoto
# DB_SSLMODE=require

# --- Seguranca ---
# Origens permitidas para CORS (separadas por virgula)
# Em producao, restringir ao dominio do frontend
# CORS_ALLOWED_ORIGINS=https://atudic.empresa.com,https://admin.empresa.com

# --- Servidor ---
# FLASK_ENV=production
# GUNICORN_WORKERS=5      # Padrao: 2 * CPU + 1

# --- GolIAs / Embeddings (busca semantica) ---
# A maioria dos providers de chat JA tem embedding integrado.
# So configure abaixo se quiser usar um provider DIFERENTE do chat.
#
# Providers com embedding proprio (usa a mesma API key do chat):
#   OpenAI (text-embedding-3-small), Gemini (text-embedding-004),
#   Grok (v2-embedding), Mistral (mistral-embed),
#   OpenRouter, Together AI
#
# Providers SEM embedding (precisa de fallback):
#   Anthropic (Claude), Groq, DeepSeek
#   → Configure EMBEDDING_PROVIDER com outro provider que voce ja tenha
#   → Ex: usa Claude para chat + Gemini para embedding
#
# EMBEDDING_PROVIDER=gemini       # Provider dedicado para embedding
# EMBEDDING_API_KEY=              # Chave (ou usa <PROVIDER>_API_KEY)
# OLLAMA_EMBED_MODEL=mxbai-embed-large  # Modelo local se tiver Ollama

# --- RBAC Hibrido ---
# Habilita overrides de permissao por usuario (default: true)
# Desabilitar temporariamente com false em caso de regressao
# RBAC_OVERRIDES_ENABLED=true

# --- Debug (desabilitar em producao) ---
# DEBUG_DB=false
